    <!-- https://w3id.org/ftr#Benchmark -->


    <owl:Class rdf:about="https://w3id.org/ftr#Benchmark">
        <rdfs:comment xml:lang="en">Benchmarks are community-specific groupings of a set of Metrics that provides a narrative of those particular ways in which that community defines FAIR for assessment purposes.</rdfs:comment>
        <rdfs:label xml:lang="en">Benchmark</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#BenchmarkScore -->


    <owl:Class rdf:about="https://w3id.org/ftr#BenchmarkScore">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dqv#QualityMeasurement"/>
        <rdfs:comment xml:lang="en">Score obtained after executing a scoring algorithm over a set of test results. The benchmark score includes a value, a log and a link to the test results used to obtain the score. </rdfs:comment>
        <rdfs:label xml:lang="en">Benchmark score</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#GuidanceContext -->


    <owl:Class rdf:about="https://w3id.org/ftr#GuidanceContext">
        <rdfs:comment xml:lang="en">Class that represents a concrete suggestion from a test. A guidance context has a title, description and points to a general guidance element (e.g., a good practice)</rdfs:comment>
        <rdfs:label xml:lang="en">Guidance context</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#Metric -->


    <owl:Class rdf:about="https://w3id.org/ftr#Metric">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dqv#Metric"/>
        <rdfs:comment xml:lang="en">Narrative description that a Test must wholly implement. Metrics may be domain-agnostic or not.</rdfs:comment>
        <rdfs:label xml:lang="en">Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#ScoringAlgorithm -->


    <owl:Class rdf:about="https://w3id.org/ftr#ScoringAlgorithm">
        <rdfs:comment xml:lang="en">A benchmark implementation in the form of an interpretative algorithm. 
Algorithms may specify the exact set of tests which are to be run by the assessment service. Algorithms contextualise the sum of all test results for a given benchmark, into a final quantitative assessment result. The execution of an algorithm yields an assessment result.</rdfs:comment>
        <rdfs:label xml:lang="en">Scoring algorithm</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#Test -->


    <owl:Class rdf:about="https://w3id.org/ftr#Test">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#DataService"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment xml:lang="en">Service, formed by an API and associated piece of code that implements a Metric, and is executed (by a FAIR assessment tool), retrieving a particular result.</rdfs:comment>
        <rdfs:label xml:lang="en">Test</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#TestExecutionActivity -->


    <owl:Class rdf:about="https://w3id.org/ftr#TestExecutionActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">The action carried out by an agent of calling an API in which a test (or set of tests) were run. The result of this activity is either a `TestResult` or a `TestResultSet`.</rdfs:comment>
        <rdfs:label xml:lang="en">Test execution activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#TestResult -->


    <owl:Class rdf:about="https://w3id.org/ftr#TestResult">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment>Output of running a test over a resource. A test result also should contain provenance metadata about the process followed to create it. `TestResult`is represented as an extension of `prov:Entity`. A test result points to the corresponding test specification through the `ftr:definedBy` property.</rdfs:comment>
        <rdfs:label xml:lang="en">Test result</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/ftr#TestResultSet -->


    <owl:Class rdf:about="https://w3id.org/ftr#TestResultSet">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Collection"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A set of FAIR test results, together with their respective metadata. Common metadata may describe the set. For example, if all results where run by a request to the same API.</rdfs:comment>
        <rdfs:label xml:lang="en">Test result set</rdfs:label>
    </owl:Class>
    


