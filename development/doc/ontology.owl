    <!-- http://purl.org/dc/terms/creator -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/creator">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">creator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/license">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">license</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://usefulinc.com/ns/doap#repository -->


    <owl:ObjectProperty rdf:about="http://usefulinc.com/ns/doap#repository">
        <rdfs:isDefinedBy rdf:resource="http://usefulinc.com/ns/doap#"/>
        <rdfs:label>repository</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#contactPoint -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#contactPoint">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">contact point</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#endpointDescription -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#endpointDescription">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">endpoint description</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#endpointURL -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#endpointURL">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">endpoint URL</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#landingPage -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#landingPage">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">landing page</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dcat#theme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#theme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">theme</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/dqv#inDimension -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dqv#inDimension">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dqv#"/>
        <rdfs:label xml:lang="en">in dimension</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#hadMember -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#hadMember">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">had member</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#used -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#used">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">used</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasAssociatedWith -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAssociatedWith">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">was associated with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasAttributedTo -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAttributedTo">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">was attributed to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasDerivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">was derived from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">was generated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasStartedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasStartedBy">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">was started by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://semanticscience.org/resource/SIO_000233 -->


    <owl:ObjectProperty rdf:about="https://semanticscience.org/resource/SIO_000233">
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label>is implementation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://semanticscience.org/resource/SIO_000234 -->


    <owl:ObjectProperty rdf:about="https://semanticscience.org/resource/SIO_000234">
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label>has implementation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://semanticscience.org/resource/SIO_000339 -->


    <owl:ObjectProperty rdf:about="https://semanticscience.org/resource/SIO_000339">
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label>is specified by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/dpv#isApplicableFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/dpv#isApplicableFor">
        <rdfs:comment>Property designed to indicate the type of digital object the test, metric, benchmark, or scoring algorithm is applicable for. See [https://github.com/OSTrails/digital-object-commons/blob/main/object_types_draft.csv](https://github.com/OSTrails/digital-object-commons/blob/main/object_types_draft.csv) for a set of supported digital object types</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
        <rdfs:label xml:lang="en">is applicable for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#assessmentTarget -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#assessmentTarget">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ftr#TestResult"/>
                    <rdf:Description rdf:about="https://w3id.org/ftr#TestResultSet"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Relationship indicating that was the resource being assessed. The property links the results of the assessment ot the resource itself. For example, a dataset with URI example.org/myData was the target of the FAIR assessment result.</rdfs:comment>
        <rdfs:label xml:lang="en">assessment target</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#hasAssociatedMetric -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#hasAssociatedMetric">
        <owl:inverseOf rdf:resource="https://w3id.org/ftr#hasBenchmark"/>
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Benchmark"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:comment>Property used to link a benchmark with the metrics included in it. A benchmark may contain many metrics</rdfs:comment>
        <rdfs:label xml:lang="en">has associated metric</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#hasBenchmark -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#hasBenchmark">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#Benchmark"/>
        <rdfs:comment xml:lang="en">Property used to link a metric to the benchmarks it belongs to. A metric may belong to many benchmarks.</rdfs:comment>
        <rdfs:label xml:lang="en">has benchmark</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#invokesTest -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#invokesTest">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#ScoringAlgorithm"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#Test"/>
        <rdfs:comment xml:lang="en">Property used to determine which concrete tests are expected to be invoked by a benchmark scoring algorithm</rdfs:comment>
        <rdfs:comment xml:lang="en">invokes test</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#outputFromAlgorithm -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#outputFromAlgorithm">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/ftr#BenchmarkScore"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#ScoringAlgorithm"/>
        <rdfs:comment xml:lang="en">Relationship to indicate which scoring algorithm was used to obtain a benchmark score from grading a set of test results.</rdfs:comment>
        <rdfs:label xml:lang="en">output from algorithm</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#outputFromTest -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#outputFromTest">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/ftr#TestResult"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#Test"/>
        <rdfs:comment xml:lang="en">Property linking a test result with its corresponding test</rdfs:comment>
        <rdfs:label>output from test</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#scoredTestResults -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#scoredTestResults">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/ftr#BenchmarkScore"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#TestResultSet"/>
        <rdfs:comment xml:lang="en">Relationship designed to link a benchmark score (which contains the value of an assessment) to the set of test results that contain the pass/fail status and are used to create the numeric value of the assessment according to the indications of a scoring algorithm</rdfs:comment>
        <rdfs:label xml:lang="en">scored test results</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#scoringFunction -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#scoringFunction">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#ScoringAlgorithm"/>
        <rdfs:range rdf:resource="https://semanticscience.org/resource/SIO_000090"/>
        <rdfs:comment xml:lang="en">Property used to link a scoring algorithm with the specification document that indicates how the scoring works. A benchmark may be implemented with one or more scoring algorithms</rdfs:comment>
        <rdfs:label xml:lang="en">scoring function</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#suggestion -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#suggestion">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#TestResult"/>
        <rdfs:range rdf:resource="https://w3id.org/ftr#GuidanceContext"/>
        <rdfs:comment xml:lang="en">Property used to link a test result with the corresponding suggestion that may be used to guide users in addressing it.</rdfs:comment>
        <rdfs:label xml:lang="en">suggestion</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ftr#supportedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ftr#supportedBy">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ftr#Metric"/>
                    <rdf:Description rdf:about="https://w3id.org/ftr#Test"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/okn/o/sd#hasSoftwareImage -->


    <owl:ObjectProperty rdf:about="https://w3id.org/okn/o/sd#hasSoftwareImage">
        <rdfs:comment>Property designed to  to link a test (service) with its corresponding software image</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/okn/o/sd"/>
        <rdfs:label xml:lang="en">has software image</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/description -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/description">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/title">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="en">title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vivoweb.org/ontology/core#abbreviation -->


    <owl:DatatypeProperty rdf:about="http://vivoweb.org/ontology/core#abbreviation">
        <rdfs:isDefinedBy rdf:resource="http://vivoweb.org/ontology/core#"/>
        <rdfs:label xml:lang="en">abbreviation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#keyword -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#keyword">
        <rdfs:comment rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">keyword</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/dcat#version -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/dcat#version">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/dcat#"/>
        <rdfs:label xml:lang="en">version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/prov#value -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#value">
        <rdfs:comment>Property used to indicate the value of a test results (i.e., pass/fail). When used in a benchmarkScore, the value may be a number that indicates the assessment score according a benchmark scoring algorihtm.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:label xml:lang="en">ended at time</rdfs:label>
        <rdfs:label xml:lang="en">value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#affectedElements -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#affectedElements">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#TestResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Elements affected by the test execution. For example, if a test assesses whether the contents of a resource comply agains a standard, this property may be used  to indicate which elements within the resource have issues.</rdfs:comment>
        <rdfs:label xml:lang="en">affected elements</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#applicationArea -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#applicationArea">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/ftr#Benchmark"/>
                    <rdf:Description rdf:about="https://w3id.org/ftr#Metric"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Area of research that a metric or benchmark is applicable for. E.g., a scientific domain.</rdfs:comment>
        <rdfs:label xml:lang="en">application area</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#completion -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#completion">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#TestResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Percentage value of completion of a test result for a given resource. For example, if the test passes, completion is expected to be 1. Otherwise, completion is a value between 0..1.</rdfs:comment>
        <rdfs:label xml:lang="en">completion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasIndeterminateExpectation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasIndeterminateExpectation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to an example resource is expected to produce an indeterminate result (an indeterminate example)</rdfs:comment>
        <rdfs:label xml:lang="en">has indeterminate expectation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasIndeterminateValidation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasIndeterminateValidation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Test"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to a resource that may be used to pass the test (an indeterminate example)</rdfs:comment>
        <rdfs:label xml:lang="en">has indeterminate validation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasNegativeExpectation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasNegativeExpectation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to a resource that is not expected to pass the metric (a negative example)</rdfs:comment>
        <rdfs:label xml:lang="en">has negative expectation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasNegativeValidation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasNegativeValidation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to a resource that does not pass the metric (a negative example)</rdfs:comment>
        <rdfs:label xml:lang="en">has negative validation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasPositiveExpectation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasPositiveExpectation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to a resource that is expected to pass the metric (a positive example)</rdfs:comment>
        <rdfs:label xml:lang="en">has positive expectation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#hasPositiveValidation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#hasPositiveValidation">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#Metric"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Property that links to a resource that may be used to pass the metric (a positive example)</rdfs:comment>
        <rdfs:label xml:lang="en">has positive validation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#log -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#log">
        <rdfs:domain rdf:resource="https://w3id.org/ftr#TestResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Log associated with the test (if any)</rdfs:comment>
        <rdfs:label xml:lang="en">log</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ftr#status -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ftr#status">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Status of the resource: For example, i.e., whether it&apos;s active or deprecated. The value of a test result is captured with prov:value.</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:DatatypeProperty>
    


