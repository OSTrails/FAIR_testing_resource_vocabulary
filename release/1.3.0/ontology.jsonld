  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "A vocabulary to define FAIR test results, metrics, benchmarks and scoring algorithms in a transparent manner."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "FAIR Testing Resource Vocabulary"
  } ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "en",
    "@value" : "A vocabulary to describe FAIR testing results, metrics, benchmarks and algorithms in a transparent manner."
  } ],
