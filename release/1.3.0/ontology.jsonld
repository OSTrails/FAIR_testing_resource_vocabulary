  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relationship designed to link a benchmark score (which contains the value of an assessment) to the set of test results that contain the pass/fail status and are used to create the numeric value of the assessment according to the indications of a scoring algorithm"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ftr#BenchmarkScore"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "scored test results"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/ftr#TestResultSet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#wasDerivedFrom"
  } ]
}, {
  "@id" : "https://w3id.org/ftr#scoringFunction",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Property used to link a scoring algorithm with the specification document that indicates how the scoring works. A benchmark may be implemented with one or more scoring algorithms"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/ftr#ScoringAlgorithm"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "scoring function"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://semanticscience.org/resource/SIO_000090"
  } ]
}, {
