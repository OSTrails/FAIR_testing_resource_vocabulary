  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Property used to determine which concrete tests are expected to be invoked by a benchmark scoring algorithm"
  }, {
    "@language" : "en",
    "@value" : "invokes test"
  } ],
